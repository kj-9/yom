{
  "name": "yom",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "yom-next": "./src/cli/index.ts"
  },
  "scripts": {
    "dev": "bun run ./src/cli/index.ts dev",
    "build": "tsc --noEmit && vite build && bun run ./src/cli/index.ts build",
    "preview": "bun run ./src/cli/index.ts preview",
    "test": "vitest run",
    "check": "tsc --noEmit",
    "format": "prettier --check \"index.html\" \"src/**/*.{ts,css}\" \"tests/**/*.ts\""
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/markdown-it": "^14.1.2",
    "markdown-it": "^14.1.0",
    "prettier": "^3.6.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
