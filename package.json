{
  "name": "@kj-9/yom",
  "version": "0.1.0-alpha.0",
  "description": "Markdown tree viewer and static site builder powered by Bun",
  "license": "MIT",
  "type": "module",
  "engines": {
    "bun": ">=1.3.0"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "README.ja.md",
    "LICENSE"
  ],
  "bin": {
    "yom-next": "./bin/yom-next"
  },
  "scripts": {
    "dev": "bun run ./src/cli/index.ts dev",
    "build": "tsc --noEmit && vite build && bun run ./src/cli/index.ts build",
    "preview": "bun run ./src/cli/index.ts preview",
    "test": "vitest run",
    "check": "tsc --noEmit",
    "dryrun-publish": "bun publish --tag alpha --dryrun  --access public",
    "format": "prettier --check \"bin/yom-next\" \"index.html\" \"src/**/*.{ts,css}\" \"tests/**/*.ts\""
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/markdown-it": "^14.1.2",
    "cac": "^6.7.14",
    "markdown-it": "^14.1.0",
    "mermaid": "^11.12.0",
    "prettier": "^3.6.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
